# Verify installations

# ============================================================

section "Installed Versions"

pct exec "$CTID" -- bash -lc '
set +e

printf "%-12s %s\n" 
"Git:" 
"$(git --version 2>/dev/null)"

printf "%-12s %s\n" 
"GitHub CLI:" 
"$(gh --version 2>/dev/null | head -n 1)"

printf "%-12s %s\n" 
"Node.js:" 
"$(node --version 2>/dev/null)"

printf "%-12s %s\n" 
"npm:" 
"$(npm --version 2>/dev/null)"

printf "%-12s %s\n" 
"Claude:" 
"$(claude --version 2>/dev/null)"

printf "%-12s %s\n" 
"Docker:" 
"$(docker --version 2>/dev/null)"

printf "%-12s %s\n" 
"Compose:" 
"$(docker compose version 2>/dev/null)"

printf "%-12s %s\n" 
"tmux:" 
"$(tmux -V 2>/dev/null)"
'

# ============================================================

# Get IP address

# ============================================================

IP_ADDRESS="$(
pct exec "$CTID" -- bash -lc 
"hostname -I | awk '{print $1}'" 
| tr -d '\r'
)"

# ============================================================

# Completion summary

# ============================================================

section "Complete"

echo "${GREEN}${BOLD}Container created successfully.${RESET}"
echo
echo "Container ID:        ${BOLD}$CTID${RESET}"
echo "Hostname:            ${BOLD}$HOSTNAME${RESET}"
echo "IP address:          ${BOLD}$IP_ADDRESS${RESET}"
echo "Application user:    ${BOLD}$APP_USER${RESET}"
echo "Application folder:  ${BOLD}$APP_DIR${RESET}"
echo

echo "${BOLD}SSH as the application user:${RESET}"
echo "  ssh $APP_USER@$IP_ADDRESS"
echo

if [[ "$ENABLE_ROOT_SSH" == "Y" ]]; then
echo "${BOLD}SSH as root:${RESET}"
echo "  ssh root@$IP_ADDRESS"
echo
fi

if [[ "$ENABLE_CONSOLE_AUTOLOGIN" == "Y" ]]; then
echo "${BOLD}Proxmox console:${RESET}"
echo "  Root auto-login is enabled."
echo
fi

echo "${BOLD}Manual next steps inside the container:${RESET}"
echo
echo "  gh auth login"
echo
echo "  claude setup-token"
echo
echo "  gh secret set CLAUDE_CODE_OAUTH_TOKEN --repo OWNER/REPOSITORY"
echo

echo "${BOLD}Commit the starter project files:${RESET}"
echo
echo "  cd $APP_DIR"
echo "  git status"
echo "  git add ."
echo "  git commit -m "Initial project structure""
echo "  git push -u origin main"
echo

warn "Do not expose password-based SSH directly to the public internet."
