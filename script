#!/usr/bin/env bash
set -euo pipefail

# newlxc / create-dev-lxc.sh
#
# Public-safe Proxmox LXC dev-container bootstrap script.
#
# What it does:
# - Creates a Debian LXC container
# - Installs updates and common tools
# - Installs Docker, Git, GitHub CLI, Node.js, Claude Code, tmux
# - Enables SSH
# - Creates a non-root app user
# - Creates /opt/<app-name>
# - Makes the app user land in /opt/<app-name> on login
# - Makes "claude" automatically run with --dangerously-skip-permissions for the app user
# - Creates starter app folders
# - Creates .gitignore, .env.example, README.md, docker-compose.yml
# - Creates .github/workflows/claude.yml
#
# Run this ON THE PROXMOX HOST as root.
#
# Security note:
# This script is meant for fast internal dev containers.
# Do not expose password SSH directly to the public internet.

# -----------------------------
# Colors
# -----------------------------

if [[ -t 1 ]]; then
  BOLD="$(tput bold || true)"
  RESET="$(tput sgr0 || true)"
  RED="$(tput setaf 1 || true)"
  GREEN="$(tput setaf 2 || true)"
  YELLOW="$(tput setaf 3 || true)"
  BLUE="$(tput setaf 4 || true)"
  MAGENTA="$(tput setaf 5 || true)"
  CYAN="$(tput setaf 6 || true)"
else
  BOLD=""
  RESET=""
  RED=""
  GREEN=""
  YELLOW=""
  BLUE=""
  MAGENTA=""
  CYAN=""
fi

info() {
  echo "${CYAN}==>${RESET} $*"
}

success() {
  echo "${GREEN}✓${RESET} $*"
}

warn() {
  echo "${YELLOW}!${RESET} $*"
}

error() {
  echo "${RED}ERROR:${RESET} $*" >&2
}

section() {
  echo
  echo "${BOLD}${BLUE}====================================================${RESET}"
  echo "${BOLD}${BLUE} $*${RESET}"
  echo "${BOLD}${BLUE}====================================================${RESET}"
}

# -----------------------------
# Helpers
# -----------------------------

require_root() {
  if [[ "$(id -u)" -ne 0 ]]; then
    error "Run this script as root on the Proxmox host."
    exit 1
  fi
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    error "Required command not found: $1"
    exit 1
  fi
}

prompt_secret_confirmed() {
  local label="$1"
  local first=""
  local second=""

  while true; do
    read -rsp "$label: " first
    echo
    read -rsp "Confirm $label: " second
    echo

    if [[ -z "$first" ]]; then
      warn "Password cannot be blank."
      continue
    fi

    if [[ "$first" != "$second" ]]; then
      warn "Passwords did not match. Try again."
      continue
    fi

    printf '%s' "$first"
    return 0
  done
}

prompt_default() {
  local label="$1"
  local default="$2"
  local value=""

  read -rp "$label [$default]: " value
  printf '%s' "${value:-$default}"
}

slugify_app_name() {
  echo "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -cs 'a-z0-9' '-' \
    | sed 's/^-//;s/-$//'
}

make_linux_username() {
  local raw="$1"
  local user

  user="$(echo "$raw" | tr '-' '_' | tr -cs 'a-z0-9_' '_')"

  if [[ ! "$user" =~ ^[a-z_] ]]; then
    user="app_${user}"
  fi

  echo "$user" | cut -c1-31
}

yes_no_default_yes() {
  local prompt="$1"
  local value=""

  read -rp "$prompt [Y/n]: " value
  value="${value:-Y}"

  [[ "$value" =~ ^[Yy]$ ]]
}

yes_no_default_no() {
  local prompt="$1"
  local value=""

  read -rp "$prompt [y/N]: " value
  value="${value:-N}"

  [[ "$value" =~ ^[Yy]$ ]]
}

# -----------------------------
# Start
# -----------------------------

clear || true

section "Proxmox Dev LXC Creator"

echo "${BOLD}This script creates a ready-to-use development LXC container.${RESET}"
echo
echo "It will ask for:"
echo "  - Container ID"
echo "  - App name"
echo "  - Optional GitHub repo URL"
echo "  - Passwords (optional)"
echo
echo "It will install:"
echo "  - Docker"
echo "  - Git"
echo "  - GitHub CLI"
echo "  - Node.js"
echo "  - Claude Code"
echo "  - tmux"
echo "  - Common dev tools"
echo

require_root
require_cmd pct
require_cmd pvesm
require_cmd pveam

# -----------------------------
# Basic prompts
# -----------------------------

section "Basic Container Details"

read -rp "Container ID, example 132: " CTID
read -rp "App name, example myapp: " APP_NAME
read -rp "GitHub repo URL, optional, example https://github.com/OWNER/REPO.git: " REPO_URL

if [[ ! "$CTID" =~ ^[0-9]+$ ]]; then
  error "Container ID must be a number."
  exit 1
fi

if [[ -z "$APP_NAME" ]]; then
  error "App name cannot be blank."
  exit 1
fi

APP_SLUG="$(slugify_app_name "$APP_NAME")"

if [[ -z "$APP_SLUG" ]]; then
  error "App name produced an empty slug."
  exit 1
fi

HOSTNAME="$APP_SLUG"
APP_USER="$(make_linux_username "$APP_SLUG")"
APP_DIR="/opt/$APP_SLUG"

# -----------------------------
# Proxmox settings
# -----------------------------

section "Proxmox Settings"

echo "Press Enter to accept each default."
echo

TEMPLATE_STORAGE="$(prompt_default "Template storage" "iso")"
DISK_STORAGE="$(prompt_default "Container disk storage" "ct-disks")"
BRIDGE="$(prompt_default "Network bridge" "vnet0")"
TEMPLATE_NAME="$(prompt_default "Debian template" "debian-12-standard_12.12-1_amd64.tar.zst")"
CPU_CORES="$(prompt_default "CPU cores" "2")"
MEMORY_MB="$(prompt_default "RAM in MB" "2048")"
SWAP_MB="$(prompt_default "Swap in MB" "1024")"
ROOTFS_SIZE="$(prompt_default "Disk size in GB" "20")"

# -----------------------------
# Passwords
# -----------------------------

section "Passwords"

ROOT_PASSWORD=""
if yes_no_default_no "Set a root password?"; then
  ROOT_PASSWORD="$(prompt_secret_confirmed "Root password for container")"
else
  # Generate a random password for the Proxmox API requirement
  # (root won't be able to log in without console auto-login)
  ROOT_PASSWORD="$(openssl rand -base64 32)"
  info "Root password set to random value (not usable for login)."
fi

echo
if yes_no_default_yes "Use the same password for app user '$APP_USER'?"; then
  APP_PASSWORD="$ROOT_PASSWORD"
else
  APP_PASSWORD="$(prompt_secret_confirmed "Password for app user '$APP_USER'")"
fi

# -----------------------------
# SSH options
# -----------------------------

section "Access Options"

if yes_no_default_yes "Enable root SSH password login?"; then
  ENABLE_ROOT_SSH="Y"
else
  ENABLE_ROOT_SSH="N"
fi

# Important: default is YES because this is intended for fast Proxmox-console access.
if yes_no_default_yes "Enable Proxmox console auto-login as root?"; then
  ENABLE_CONSOLE_AUTOLOGIN="Y"
else
  ENABLE_CONSOLE_AUTOLOGIN="N"
fi

# -----------------------------
# Git identity
# -----------------------------

section "Git Identity"

echo "This only sets Git commit identity inside the new container."
echo "Leave defaults or type your own."
echo

GIT_NAME="$(prompt_default "Git user.name" "devuser")"
GIT_EMAIL="$(prompt_default "Git user.email" "dev@example.com")"

# -----------------------------
# Confirmation
# -----------------------------

section "Planned Setup"

echo "CT ID:              ${BOLD}$CTID${RESET}"
echo "Hostname:           ${BOLD}$HOSTNAME${RESET}"
echo "App name:           ${BOLD}$APP_NAME${RESET}"
echo "App slug:           ${BOLD}$APP_SLUG${RESET}"
echo "App user:           ${BOLD}$APP_USER${RESET}"
echo "App directory:      ${BOLD}$APP_DIR${RESET}"
echo "Repo URL:           ${BOLD}${REPO_URL:-none}${RESET}"
echo "Template storage:   ${BOLD}$TEMPLATE_STORAGE${RESET}"
echo "Template:           ${BOLD}$TEMPLATE_NAME${RESET}"
echo "Disk storage:       ${BOLD}$DISK_STORAGE${RESET}"
echo "Disk size:          ${BOLD}${ROOTFS_SIZE}G${RESET}"
echo "Bridge:             ${BOLD}$BRIDGE${RESET}"
echo "CPU cores:          ${BOLD}$CPU_CORES${RESET}"
echo "RAM:                ${BOLD}${MEMORY_MB} MB${RESET}"
echo "Swap:               ${BOLD}${SWAP_MB} MB${RESET}"
echo "Root SSH login:     ${BOLD}$ENABLE_ROOT_SSH${RESET}"
echo "Console auto-login: ${BOLD}$ENABLE_CONSOLE_AUTOLOGIN${RESET}"
echo "Git name:           ${BOLD}$GIT_NAME${RESET}"
echo "Git email:          ${BOLD}$GIT_EMAIL${RESET}"
echo

read -rp "Continue? Type yes: " CONFIRM

if [[ "$CONFIRM" != "yes" ]]; then
  warn "Cancelled."
  exit 1
fi

# -----------------------------
# Pre-flight checks
# -----------------------------

section "Pre-flight Checks"

if pct status "$CTID" >/dev/null 2>&1; then
  error "CT $CTID already exists."
  exit 1
fi

if ! pvesm status | awk 'NR>1 {print $1}' | grep -qx "$TEMPLATE_STORAGE"; then
  error "Template storage '$TEMPLATE_STORAGE' not found."
  pvesm status
  exit 1
fi

if ! pvesm status | awk 'NR>1 {print $1}' | grep -qx "$DISK_STORAGE"; then
  error "Disk storage '$DISK_STORAGE' not found."
  pvesm status
  exit 1
fi

success "Storage checks passed."

# -----------------------------
# Template
# -----------------------------

section "Template Setup"

info "Updating Proxmox template list..."
pveam update

info "Checking Debian template..."
if ! pvesm list "$TEMPLATE_STORAGE" | grep -q "$TEMPLATE_NAME"; then
  info "Downloading template: $TEMPLATE_NAME"
  pveam download "$TEMPLATE_STORAGE" "$TEMPLATE_NAME"
else
  success "Template already exists."
fi

# -----------------------------
# Create LXC
# -----------------------------

section "Creating LXC Container"

info "Creating CT $CTID..."

pct create "$CTID" "$TEMPLATE_STORAGE:vztmpl/$TEMPLATE_NAME" \
  --hostname "$HOSTNAME" \
  --cores "$CPU_CORES" \
  --memory "$MEMORY_MB" \
  --swap "$SWAP_MB" \
  --rootfs "$DISK_STORAGE:${ROOTFS_SIZE}" \
  --net0 "name=eth0,bridge=$BRIDGE,ip=dhcp" \
  --unprivileged 1 \
  --features nesting=1,keyctl=1 \
  --password "$ROOT_PASSWORD" \
  --start 1

success "Container created."

info "Waiting for container to boot..."
sleep 10

# -----------------------------
# Base packages
# -----------------------------

section "Installing Base Packages"

pct exec "$CTID" -- bash -lc '
set -e
apt update
DEBIAN_FRONTEND=noninteractive apt full-upgrade -y
DEBIAN_FRONTEND=noninteractive apt install -y \
  curl wget git sudo nano vim ca-certificates gnupg lsb-release \
  unzip zip jq htop tmux openssh-server build-essential \
  python3 python3-pip python3-venv
'

success "Base packages installed."

# -----------------------------
# SSH
# -----------------------------

section "Configuring SSH"

if [[ "$ENABLE_ROOT_SSH" =~ ^[Yy]$ ]]; then
  pct exec "$CTID" -- bash -lc '
set -e
sed -i "s/^#*PermitRootLogin.*/PermitRootLogin yes/" /etc/ssh/sshd_config
sed -i "s/^#*PasswordAuthentication.*/PasswordAuthentication yes/" /etc/ssh/sshd_config
systemctl enable --now ssh
systemctl restart ssh
'
  warn "Root SSH password login is enabled. Do not expose this CT to the public internet."
else
  pct exec "$CTID" -- bash -lc '
set -e
sed -i "s/^#*PermitRootLogin.*/PermitRootLogin no/" /etc/ssh/sshd_config
sed -i "s/^#*PasswordAuthentication.*/PasswordAuthentication yes/" /etc/ssh/sshd_config
systemctl enable --now ssh
systemctl restart ssh
'
  success "Root SSH login disabled. Password login remains enabled for non-root users."
fi

if [[ "$ENABLE_CONSOLE_AUTOLOGIN" =~ ^[Yy]$ ]]; then
  info "Enabling Proxmox console auto-login as root..."
  pct exec "$CTID" -- bash -lc '
set -e
mkdir -p /etc/systemd/system/container-getty@1.service.d
cat > /etc/systemd/system/container-getty@1.service.d/override.conf <<'"'"'EOF'"'"'
[Service]
ExecStart=
ExecStart=-/sbin/agetty --autologin root --noclear --keep-baud 38400,115200,9600 tty1 linux
EOF
systemctl daemon-reload
systemctl restart container-getty@1.service || true
'
  warn "Console auto-login is enabled."
fi

# -----------------------------
# GitHub CLI
# -----------------------------

section "Installing GitHub CLI"

pct exec "$CTID" -- bash -lc '
set -e
mkdir -p -m 755 /etc/apt/keyrings
wget -qO- https://cli.github.com/packages/githubcli-archive-keyring.gpg \
  | tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null
chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
  > /etc/apt/sources.list.d/github-cli.list
apt update
DEBIAN_FRONTEND=noninteractive apt install -y gh
'

success "GitHub CLI installed."

# -----------------------------
# Node.js
# -----------------------------

section "Installing Node.js"

pct exec "$CTID" -- bash -lc '
set -e
curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
DEBIAN_FRONTEND=noninteractive apt install -y nodejs
'

success "Node.js installed."

# -----------------------------
# Claude Code
# -----------------------------

section "Installing Claude Code"

pct exec "$CTID" -- bash -lc '
set -e
npm install -g @anthropic-ai/claude-code
'

success "Claude Code installed."

# -----------------------------
# Docker
# -----------------------------

section "Installing Docker"

pct exec "$CTID" -- bash -lc '
set -e
install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/debian/gpg -o /etc/apt/keyrings/docker.asc
chmod a+r /etc/apt/keyrings/docker.asc
echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/debian $(. /etc/os-release && echo "$VERSION_CODENAME") stable" \
  > /etc/apt/sources.list.d/docker.list
apt update
DEBIAN_FRONTEND=noninteractive apt install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
systemctl enable --now docker
'

success "Docker installed."

# -----------------------------
# App user and project directory
# -----------------------------

section "Creating App User And Project Directory"

pct exec "$CTID" -- bash -lc "
set -e

if ! id '$APP_USER' >/dev/null 2>&1; then
  adduser --disabled-password --gecos '' '$APP_USER'
fi

echo '$APP_USER:$APP_PASSWORD' | chpasswd

usermod -aG sudo,docker '$APP_USER'

echo '$APP_USER ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/$APP_USER
chmod 440 /etc/sudoers.d/$APP_USER

mkdir -p '$APP_DIR'
chown -R '$APP_USER:$APP_USER' '$APP_DIR'
"

success "App user and project directory created."

# -----------------------------
# Shell behavior
# -----------------------------

section "Configuring App User Shell"

pct exec "$CTID" -- bash -lc "
set -e

cat >> /home/$APP_USER/.bashrc <<'EOF'

# Start in app project folder
cd $APP_DIR 2>/dev/null || cd ~

# Run Claude Code with dangerous permissions automatically.
# This only works as a non-root user. Claude blocks this flag as root.
alias claude='claude --dangerously-skip-permissions'
EOF

chown '$APP_USER:$APP_USER' /home/$APP_USER/.bashrc
"

success "App user shell configured."

# -----------------------------
# Starter files
# -----------------------------

section "Creating Starter Project Files"

HOST_TMP="$(mktemp -d)"
trap 'rm -rf "$HOST_TMP"' EXIT

mkdir -p "$HOST_TMP/.github/workflows"

cat > "$HOST_TMP/.gitignore" <<'EOF'
# Secrets
.env
.env.*
!.env.example

# Runtime data - do not commit live data
data/postgres/
data/uploads/
data/logs/
*.sqlite
*.sqlite3
*.db

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
npm-debug.log*

# Logs
*.log
logs/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Docker local overrides
docker-compose.override.yml
EOF

cat > "$HOST_TMP/.env.example" <<EOF
APP_NAME=$APP_NAME
APP_BASE_URL=https://example.com
SECRET_KEY=change-me

DATABASE_URL=postgresql://app:app_password@db:5432/app
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me

MOCK_MODE=true
EOF

cat > "$HOST_TMP/README.md" <<EOF
# $APP_NAME

Self-hosted app project.

## Rebuild Goal

This repository should contain everything needed to rebuild the app in a fresh LXC container.

Do not commit:

- .env
- database files
- uploaded media
- logs

## Recommended Install Path

$APP_DIR

## First Manual Steps

SSH into the container as the app user:

\`\`\`bash
ssh $APP_USER@CONTAINER_IP
\`\`\`

Authenticate GitHub CLI:

\`\`\`bash
gh auth login
\`\`\`

Generate Claude Code OAuth token:

\`\`\`bash
claude setup-token
\`\`\`

Set GitHub Actions secret:

\`\`\`bash
gh secret set CLAUDE_CODE_OAUTH_TOKEN --repo OWNER/REPO
\`\`\`
EOF

cat > "$HOST_TMP/docker-compose.yml" <<'EOF'
services:
  app:
    build: .
    container_name: app
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "8080:8000"
    volumes:
      - ./data/uploads:/app/data/uploads
      - ./data/logs:/app/data/logs
    depends_on:
      - db

  db:
    image: postgres:16
    container_name: app-db
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${POSTGRES_DB:-app}
      POSTGRES_USER: ${POSTGRES_USER:-app}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-change-me}
    volumes:
      - ./data/postgres:/var/lib/postgresql/data
EOF

cat > "$HOST_TMP/.github/workflows/claude.yml" <<'EOF'
name: Claude Code

on:
  issue_comment:
    types: [created]
  pull_request_review_comment:
    types: [created]
  pull_request_review:
    types: [submitted]
  issues:
    types: [opened, assigned]

jobs:
  claude:
    if: |
      (github.event_name == 'issue_comment' && contains(github.event.comment.body, '@claude')) ||
      (github.event_name == 'pull_request_review_comment' && contains(github.event.comment.body, '@claude')) ||
      (github.event_name == 'pull_request_review' && contains(github.event.review.body, '@claude')) ||
      (github.event_name == 'issues' && (contains(github.event.issue.body, '@claude') || contains(github.event.issue.title, '@claude')))
    runs-on: ubuntu-latest

    permissions:
      contents: write
      pull-requests: write
      issues: write
      id-token: write
      actions: read

    steps:
      - name: Run Claude Code
        uses: anthropics/claude-code-action@v1
        with:
          claude_code_oauth_token: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}
EOF

pct exec "$CTID" -- bash -lc "
set -e
mkdir -p '$APP_DIR'
mkdir -p '$APP_DIR/app' '$APP_DIR/docs' '$APP_DIR/scripts' '$APP_DIR/deploy' '$APP_DIR/data/postgres' '$APP_DIR/data/uploads' '$APP_DIR/data/logs' '$APP_DIR/.github/workflows'
chown -R '$APP_USER:$APP_USER' '$APP_DIR'
"

pct push "$CTID" "$HOST_TMP/.gitignore" "$APP_DIR/.gitignore" --perms 0644
pct push "$CTID" "$HOST_TMP/.env.example" "$APP_DIR/.env.example" --perms 0644
pct push "$CTID" "$HOST_TMP/README.md" "$APP_DIR/README.md" --perms 0644
pct push "$CTID" "$HOST_TMP/docker-compose.yml" "$APP_DIR/docker-compose.yml" --perms 0644
pct push "$CTID" "$HOST_TMP/.github/workflows/claude.yml" "$APP_DIR/.github/workflows/claude.yml" --perms 0644

pct exec "$CTID" -- bash -lc "
set -e
chown -R '$APP_USER:$APP_USER' '$APP_DIR'
"

success "Starter project files created."

# -----------------------------
# Git initialization
# -----------------------------

section "Initializing Git Repository"

pct exec "$CTID" -- su - "$APP_USER" -c "
set -e
cd '$APP_DIR'

if [ ! -d .git ]; then
  git init
  git branch -M main
fi

if [ -n '$REPO_URL' ]; then
  if git remote get-url origin >/dev/null 2>&1; then
    git remote set-url origin '$REPO_URL'
  else
    git remote add origin '$REPO_URL'
  fi
fi

git config --global user.name '$GIT_NAME'
git config --global user.email '$GIT_EMAIL'
"

success "Git initialized."

# -----------------------------
# Versions
# -----------------------------

section "Installed Versions"

pct exec "$CTID" -- bash -lc '
set +e
printf "%-10s %s\n" "git:" "$(git --version 2>/dev/null)"
printf "%-10s %s\n" "gh:" "$(gh --version 2>/dev/null | head -n1)"
printf "%-10s %s\n" "node:" "$(node --version 2>/dev/null)"
printf "%-10s %s\n" "npm:" "$(npm --version 2>/dev/null)"
printf "%-10s %s\n" "claude:" "$(claude --version 2>/dev/null)"
printf "%-10s %s\n" "docker:" "$(docker --version 2>/dev/null)"
printf "%-10s %s\n" "compose:" "$(docker compose version 2>/dev/null)"
printf "%-10s %s\n" "tmux:" "$(tmux -V 2>/dev/null)"
'

IP="$(pct exec "$CTID" -- bash -lc "hostname -I | awk '{print \$1}'" | tr -d '\r')"

# -----------------------------
# Complete
# -----------------------------

section "Complete"

echo "${GREEN}Container created successfully.${RESET}"
echo
echo "Container ID:       ${BOLD}$CTID${RESET}"
echo "Hostname:           ${BOLD}$HOSTNAME${RESET}"
echo "IP:                 ${BOLD}$IP${RESET}"
echo "App user:           ${BOLD}$APP_USER${RESET}"
echo "App directory:      ${BOLD}$APP_DIR${RESET}"
echo
echo "${BOLD}SSH as app user:${RESET}"
echo "  ssh $APP_USER@$IP"
echo

if [[ "$ENABLE_ROOT_SSH" =~ ^[Yy]$ ]]; then
  echo "${BOLD}SSH as root:${RESET}"
  echo "  ssh root@$IP"
  echo
fi

echo "${BOLD}Manual next steps inside the container:${RESET}"
echo "  gh auth login"
echo "  claude setup-token"
echo "  gh secret set CLAUDE_CODE_OAUTH_TOKEN --repo OWNER/REPO"
echo
echo "${BOLD}Then commit starter files:${RESET}"
echo "  cd $APP_DIR"
echo "  git status"
echo "  git add ."
echo "  git commit -m \"Initial project structure\""
echo "  git push -u origin main"
echo

warn "Security reminder: this is a convenience dev container. Do not expose password SSH to the public internet."
