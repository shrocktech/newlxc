#!/usr/bin/env bash
set -euo pipefail

# newlxc

#

# Generic Proxmox LXC development-container bootstrap script.

#

# Run this script on the Proxmox host as root.

#

# It creates a Debian 12 LXC and installs:

# - Docker and Docker Compose

# - Git

# - GitHub CLI

# - Node.js

# - Claude Code

# - tmux

# - Python and common development tools

#

# It also:

# - Creates a non-root application user

# - Creates /opt/<app-name>

# - Opens that folder automatically when the app user logs in

# - Makes "claude" use --dangerously-skip-permissions

# - Creates starter project folders and files

# - Creates a Claude GitHub Actions workflow

# - Enables Proxmox console root auto-login by default

#

# Security warning:

# This is intended for private development containers.

# Do not expose password-based SSH directly to the public internet.

# ============================================================

# Colors and output helpers

# ============================================================

if [[ -t 1 ]]; then
BOLD="$(tput bold 2>/dev/null || true)"
RESET="$(tput sgr0 2>/dev/null || true)"
RED="$(tput setaf 1 2>/dev/null || true)"
GREEN="$(tput setaf 2 2>/dev/null || true)"
YELLOW="$(tput setaf 3 2>/dev/null || true)"
BLUE="$(tput setaf 4 2>/dev/null || true)"
CYAN="$(tput setaf 6 2>/dev/null || true)"
else
BOLD=""
RESET=""
RED=""
GREEN=""
YELLOW=""
BLUE=""
CYAN=""
fi

section() {
echo
echo "${BOLD}${BLUE}============================================================${RESET}"
echo "${BOLD}${BLUE} $*${RESET}"
echo "${BOLD}${BLUE}============================================================${RESET}"
}

info() {
echo "${CYAN}==>${RESET} $*"
}

success() {
echo "${GREEN}✓${RESET} $*"
}

warn() {
echo "${YELLOW}!${RESET} $*"
}

error() {
echo "${RED}ERROR:${RESET} $*" >&2
}

# ============================================================

# Helper functions

# ============================================================

require_root() {
if [[ "$(id -u)" -ne 0 ]]; then
error "Run this script as root on the Proxmox host."
exit 1
fi
}

require_command() {
local command_name="$1"

```
if ! command -v "$command_name" >/dev/null 2>&1; then
    error "Required command was not found: $command_name"
    exit 1
fi
```

}

prompt_default() {
local label="$1"
local default_value="$2"
local entered_value=""

```
read -rp "$label [$default_value]: " entered_value
printf '%s' "${entered_value:-$default_value}"
```

}

prompt_yes_default() {
local label="$1"
local entered_value=""

```
read -rp "$label [Y/n]: " entered_value
entered_value="${entered_value:-Y}"

[[ "$entered_value" =~ ^[Yy]$ ]]
```

}

prompt_no_default() {
local label="$1"
local entered_value=""

```
read -rp "$label [y/N]: " entered_value
entered_value="${entered_value:-N}"

[[ "$entered_value" =~ ^[Yy]$ ]]
```

}

prompt_secret_confirmed() {
local label="$1"
local first_value=""
local second_value=""

```
while true; do
    read -rsp "$label: " first_value
    echo
    read -rsp "Confirm $label: " second_value
    echo

    if [[ -z "$first_value" ]]; then
        warn "Password cannot be blank."
        continue
    fi

    if [[ "$first_value" != "$second_value" ]]; then
        warn "Passwords did not match. Try again."
        continue
    fi

    printf '%s' "$first_value"
    return 0
done
```

}

slugify() {
echo "$1" 
| tr '[:upper:]' '[:lower:]' 
| tr -cs 'a-z0-9' '-' 
| sed 's/^-//;s/-$//'
}

make_linux_username() {
local raw_value="$1"
local username=""

```
username="$(echo "$raw_value" \
    | tr '-' '_' \
    | tr -cs 'a-z0-9_' '_')"

if [[ ! "$username" =~ ^[a-z_] ]]; then
    username="app_${username}"
fi

echo "$username" | cut -c1-31
```

}

validate_positive_integer() {
local label="$1"
local value="$2"

```
if [[ ! "$value" =~ ^[0-9]+$ ]] || [[ "$value" -lt 1 ]]; then
    error "$label must be a positive whole number."
    exit 1
fi
```

}

